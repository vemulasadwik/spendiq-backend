# ── Server ────────────────────────────────────────────────
PORT=5000

# ── JWT ───────────────────────────────────────────────────
# Change this to a long random string in production!
JWT_SECRET=spendiq_super_secret_jwt_key_change_in_prod
JWT_EXPIRES_IN=7d

# ── Database ──────────────────────────────────────────────
DB_PATH=./db/spendiq.db

# ── File Uploads ──────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=5

# ── CORS ─────────────────────────────────────────────────
CLIENT_URL=http://localhost:3000
